        <td>Homologação</td>
      </tr>
      <tr>
        <td><strong>Responsável QA</strong></td>
        <td>Matheus H Campos</td>
      </tr>
      <tr>
        <td><strong>PO do Projeto</strong></td>
        <td>Bruna Miguel</td>
      </tr>
      <tr>
        <td><strong>Data Planejada</strong></td>
        <td>08/07/2026</td>
      </tr>
