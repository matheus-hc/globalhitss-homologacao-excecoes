        <th style="width: 20%">Caso de Teste</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><strong>CV-EX-001</strong></td>
        <td>Validação de ajuste solicitado pelo Gestor (Rejeitado Gestor)</td>
        <td>CT-EX-001</td>
      </tr>
      <tr>
        <td><strong>CV-EX-002</strong></td>
        <td>Validação de recusa comercial pelo Cliente (Rejeitado Cliente)</td>
        <td>CT-EX-002</td>
      </tr>
      <tr>
